      "required": true,
      "install_path": "tools/vendor/hugo-0.157.0",
      "launch_path": "hugo.exe",
      "source_candidates": [
        "tools/_downloads/bootstrap/hugo_extended_0.157.0_windows-amd64.zip",
        "https://github.com/gohugoio/hugo/releases/download/v0.157.0/hugo_extended_0.157.0_windows-amd64.zip"
