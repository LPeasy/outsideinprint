    {
      "name": "pwsh",
      "kind": "portable-download",
      "version": "7.5.0",
      "required": true,
      "install_path": "tools/vendor/pwsh-7.5.0",
      "launch_path": "pwsh.exe",
      "source_candidates": [
        "tools/_downloads/bootstrap/PowerShell-7.5.0-win-x64.zip",
