{
  "schema_version": "1.1",
  "platform": "windows",
  "cache_strategy": "repo-local-with-optional-shared-cache",
  "tools": [
    {
      "name": "node",
      "kind": "portable-download",
      "version": "20.20.2",
      "required": true,
      "install_path": "tools/vendor/node-toolchain-20.20.2",
      "launch_path": "node-v20.20.2-win-x64/node.exe",
      "source_candidates": [
        "tools/_downloads/bootstrap/node-v20.20.2-win-x64.zip",
        "https://nodejs.org/dist/v20.20.2/node-v20.20.2-win-x64.zip"
      ],
      "asset_name": "node-v20.20.2-win-x64.zip",
      "validate": {
        "arguments": [
          "--version"
        ],
        "match_regex": "^v20\\.20\\.2"
      },
      "notes": "Pinned Node toolchain for the repo's 20.x contract. Bootstrap from tools/_downloads/bootstrap first."
    },
    {
      "name": "npm",
      "kind": "portable-download",
      "version": "20.20.2",
      "required": false,
      "install_path": "tools/vendor/node-toolchain-20.20.2",
