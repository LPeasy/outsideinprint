{{- $pages := partial "archive/resolve-pages.html" (dict "site" site "mode" "dialogue") -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML -}}
<rss version="2.0">
  <channel>
    <title>{{ .Title }} | {{ site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Params.description | default site.Title }}</description>
    <generator>Hugo</generator>
    {{- with index $pages 0 }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{- end }}
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <guid>{{ .Permalink }}</guid>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ partial "metadata_description.html" . | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
